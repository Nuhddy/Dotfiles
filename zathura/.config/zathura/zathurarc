set guioptions ""
set window-title-home-tilde true
set statusbar-home-tilde true
set zoom-center true
set zoom-step 5
set selection-clipboard clipboard
set show-recent 5

# Start flavours
# Base16 Bubblified
# Author: Nuhddy

set default-bg                  "#161616"
set default-fg                  "#222222"

set statusbar-fg                "#cccccc"
set statusbar-bg                "#444444"

set inputbar-bg                 "#161616"
set inputbar-fg                 "#e5e5e5"

set notification-bg             "#161616"
set notification-fg             "#e5e5e5"

set notification-error-bg       "#161616"
set notification-error-fg       "#d23d3d"

set notification-warning-bg     "#161616"
set notification-warning-fg     "#d23d3d"

set highlight-color             "#fea63c"
set highlight-active-color      "#66a9b9"

set completion-bg               "#222222"
set completion-fg               "#66a9b9"

set completion-highlight-fg     "#e5e5e5"
set completion-highlight-bg     "#66a9b9"

set recolor-lightcolor          "#161616"
set recolor-darkcolor           "#d5d5d5"
