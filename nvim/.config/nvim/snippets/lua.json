{
    "Assign & require, return on error": {
        "prefix": "okreq",
        "description": "Import module in protected call. Return on error.",
        "body": [
            "local ${1:status_ok}, ${2:_} = pcall(require, '$3')",
            "if not $1 then",
            "\treturn",
            "end",
            "$0"
        ]
    }
}
